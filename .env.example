# ════════════════════════════════════════════
# BOT DE TELEGRAM
# Obtén el token con @BotFather en Telegram
# ════════════════════════════════════════════
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-example

# ════════════════════════════════════════════
# ROLES Y RESTAURANTES
# Usa IDs numéricos de Telegram separados por comas
# Consigue tu ID con @userinfobot en Telegram
# ════════════════════════════════════════════

# Dueño — acceso total a los dos restaurantes
ADMIN_IDS=123456789

# Supervisoras (una por restaurante)
OASIS_SUPERVISOR_IDS=111111111
DALI_SUPERVISOR_IDS=222222222

# Jefes de cocina
OASIS_CHIEF_IDS=333333333
DALI_CHIEF_IDS=444444444

# Cajeros/as
OASIS_CASHIER_IDS=555555555,666666666
DALI_CASHIER_IDS=777777777,888888888

# Meseros/as — pueden cambiar de restaurante con /mi_restaurante
# Añade tantos IDs como meseros haya (separados por comas)
OASIS_MESERO_IDS=901010101,902020202
DALI_MESERO_IDS=903030303,904040404

# ════════════════════════════════════════════
# PANEL WEB
# URL pública del panel (para mostrar en el bot)
# ════════════════════════════════════════════
WEB_URL=https://restauranteoasis.vimio.store

# ════════════════════════════════════════════
# BASE DE DATOS
# Ruta dentro del contenedor Docker
# (el volumen persiste los datos entre deploys)
# ════════════════════════════════════════════
DB_PATH=/data/restaurante.db

# ════════════════════════════════════════════
# FACEBOOK MONITOR
# Slug de la página pública (parte final de la URL)
# Ej: facebook.com/OasisdeDali → slug = OasisdeDali
# ════════════════════════════════════════════
FB_PAGE_SLUG=OasisdeDali

# ════════════════════════════════════════════
# COMPROBANTES DE PAGO
# Carpeta donde se guardan las fotos de comprobantes
# (dentro del volumen Docker /data)
# ════════════════════════════════════════════
COMPROBANTES_DIR=/data/comprobantes

# ════════════════════════════════════════════
# VERIFICACIÓN DE COMPROBANTES (IA)
# API key de Anthropic para leer las fotos
# Cuentas QR/bancarias de cada restaurante
# (número sin espacios: teléfono, CI, o nro de cuenta)
# ════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
OASIS_ACCOUNT_NUMBER=77712345
DALI_ACCOUNT_NUMBER=77798765
